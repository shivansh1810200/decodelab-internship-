import random
import string

print("=" * 40)
print("      RANDOM PASSWORD GENERATOR")
print("=" * 40)

# Ask user for password length
length = int(input("Enter password length: "))

# Characters to use
characters = (
    string.ascii_letters +
    string.digits +
    string.punctuation
)

# Generate password
password = ""

for i in range(length):
    password += random.choice(characters)

# Display password
print("\nGenerated Password:")
print(password)
